media_am = mean(na.omit(NHANES_12$Poverty))
desv_pad = sd(na.omit(NHANES_12$Poverty))
n = length(na.omit(NHANES_12$Poverty))
c(media_am, desv_pad, n)
c(media_am, desv_pad, n, erro_pad)
erro_pad = desv_pad/sqrt(n)
c(media_am, desv_pad, n, erro_pad)
c("Média:" = media_am,
"Desvio padrão:" = desv_pad,
"Erro padrão:" = erro_pad,
"Amostras:" = n)
plot(NHANES$Poverty)
plot(NHANES$Poverty)
lm(NHANES$Poverty)
cat("Intervalo de confiança: [", IC_inferior, "," IC_superior, "]")
cat("Intervalo de confiança: [", IC_inferior, "," IC_superior, "]")
cat("Intervalo de confiança: [", IC_inferior, ",", IC_superior, "]")
alpha <- 0.05
z <- qnorm(1 - alpha/2)
IC_inferior = media_am - z * erro_pad
IC_superior = media_am + z * erro_pad
cat("Intervalo de confiança: [", IC_inferior, ",", IC_superior, "]")
mediana_am = median(na.omit(NHANES_12$Poverty))
c("Mediana:" = mediana_am,
"Média:" = media_am,
"Desvio padrão:" = desv_pad,
"Erro padrão:" = erro_pad,
"Amostras:" = n)
mediana_am_23 = median(na.omit(NHANES_23$INDFMMPI))
media_am_23 = mean(na.omit(NHANES_23$INDFMMPI))
desv_pad_23 = sd(na.omit(NHANES_23$INDFMMPI))
n_23 = length(na.omit(NHANES_23$INDFMMPI))
erro_pad_23 = desv_pad/sqrt(n)
c("Mediana:" = mediana_am_23,
"Média:" = media_am_23,
"Desvio padrão:" = desv_pad_23,
"Erro padrão:" = erro_pad_23,
"Amostras:" = n_23)
alpha <- 0.05
z <- qnorm(1 - alpha/2)
IC_inferior_23 = media_am_23 - z * erro_pad_23
IC_superior_23 = media_am_23 + z * erro_pad_23
cat("Intervalo de confiança: [", IC_inferior_23, ",", IC_superior_23, "]")
plot(NHANES_23$INDFMMPI)
