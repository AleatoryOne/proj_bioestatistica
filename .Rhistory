library(NHANES)
data(NHANES)
## Base de dados NHANES (2020)
if(!require(haven)) install.packages("haven")
library(haven)
library(dplyr)
arquivos = list.files(path = "databases",
pattern = "\\.xpt$",
full.names = TRUE)
lista_dados = lapply(arquivos, read_xpt)
NHANES_20 = Reduce(function(x, y) {
full_join(x, y, by = "SEQN")
}, lista_dados)
rm(arquivos)
rm(lista_dados)
library(ggplot2)
ggplot(NHANES, aes(HealthGen, Poverty, fill=HealthGen)) +
geom_boxplot() +
theme_gray() +
scale_fill_brewer(palette="PuOr") +
stat_summary(fun = mean, geom = "line", aes(group = 1), color = "darkgreen")
