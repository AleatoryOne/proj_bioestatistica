ggplot(NHANES_20_t3e, aes(reorder(IND310_txt, IND310), fill=HUQ090_txt)) +
geom_bar(aes(y = after_stat(count / tapply(count, x, sum)[x])),
position = "dodge") +
scale_y_continuous(labels = scales::percent) +
labs(y = "Percentage of people") +
theme_gray()
r
help(r)
