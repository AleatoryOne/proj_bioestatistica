# Análise de variâncias -----
ggplot(NHANES, aes(sample=Poverty))+
geom_qq() +
geom_qq_line() +
facet_grid(~Depressed)
modelo1 = aov(Poverty ~ Depressed, data=NHANES)
res1 = residuals(modelo1)
res1
hist(res1)
shapiro.test(res1)
library(car)
leveneTest(Poverty ~ HealthGen, data = NHANES)
leveneTest(Poverty ~ Depressed, data = NHANES)
oneway.test(Poverty ~ Depressed, data=NHANES, var.equal = FALSE)
kruskal.test(Poverty ~ Depressed, data=NHANES)
ggplot(NHANES, aes(sample=Poverty))+
geom_qq() +
geom_qq_line() +
facet_grid(~LittleInteres)
ggplot(NHANES, aes(sample=Poverty))+
geom_qq() +
geom_qq_line() +
facet_grid(~LittleInterest)
modelo1 = aov(Poverty ~ LittleInterest, data=NHANES)
res1 = residuals(modelo1)
modelo4 = aov(Poverty ~ LittleInterest, data=NHANES)
res4 = residuals(modelo4)
'| O teste de Shapiro para normalidade dos resíduos não pode ser feito pois n >> 5000.'
hist(res4)
hist(res3)
modelo3 = aov(Poverty ~ Depressed, data=NHANES)
res3 = residuals(modelo3)
'| O teste de Shapiro para normalidade dos resíduos não pode ser feito pois n >> 5000.'
hist(res3)
par(mfrow=c(1,2))
hist(res3)
hist(res4)
'| O histograma mostra uma distribuição não normal, além de mostrar uma distribuição dos resíduos praticamente idêntica à da depressão.
| Isto é mais um indício de que as duas variáveis estão interligadas.'
oneway.test(Poverty ~ LittleInterest, data=NHANES, var.equal = FALSE)
kruskal.test(Poverty ~ LittleInterest, data=NHANES)
