# Poverty: "INDFMMPI"
# HealthGen: "HUQ010"
# Gender: "RIAGENDR"
# Ethnicity: "RIDRETH1"

library(dplyr)
NHANES_20_t1 = NHANES_20 %>%
  mutate(HUQ010_txt = case_when(
    HUQ010 == "1" ~ "Excellent",
    HUQ010 == "2" ~ "Vgood",
    HUQ010 == "3" ~ "Good",
    HUQ010 == "4" ~ "Fair", 
    HUQ010 == "5" ~ "Poor",
    TRUE ~ NA
  ))

NHANES_20_t1 = NHANES_20_t1 %>%
  mutate(DMDHRAGZ_txt = case_when(
    DMDHRAGZ == "1" ~ "<20",
    DMDHRAGZ == "2" ~ "20-39",
    DMDHRAGZ == "3" ~ "40-59",
    DMDHRAGZ == "4" ~ ">=60", 
    TRUE ~ NA
  ))

NHANES_20_t1 = NHANES_20_t1 %>%
  mutate(RIAGENDR_txt = case_when(
    RIAGENDR == "1" ~ "Male",
    RIAGENDR == "2" ~ "Female",
    TRUE ~ NA
  ))

NHANES_20_t1 = NHANES_20_t1 %>%
  mutate(RIDRETH1_txt = case_when(
    RIDRETH1 == "1" ~ "Mexican",
    RIDRETH1 == "2" ~ "Other Hispanic",
    RIDRETH1 == "3" ~ "Non-Hispanic White",
    RIDRETH1 == "4" ~ "Non-Hispanic Black",
    RIDRETH1 == "5" ~ "Other",
    TRUE ~ NA
  ))

NHANES_20_t1 = NHANES_20_t1 %>%
  mutate(DMDMARTZ_txt = case_when(
    DMDMARTZ == "1" ~ "Married/Living with partner",
    DMDMARTZ == "2" ~ "Widowed/Divorced/Separated",
    DMDMARTZ == "3" ~ "Never Married",
    TRUE ~ NA
  ))

# Quais idades possuem maior índice de pobreza (2020)? -----

library(ggplot2)
ggplot(NHANES_20_t1, aes(reorder(DMDHRAGZ_txt, DMDHRAGZ), INDFMMPI, fill=HUQ010_txt)) + 
  geom_boxplot() +
  theme_gray() +
  scale_fill_brewer(palette="Spectral") +
  stat_summary(fun = median, geom = "line", aes(group=HUQ010_txt, color=HUQ010_txt))

'| Desta vez, não há nenhum padrão notável que correlacione idades e saúde.'
'| Também percebem-se ausências em algumas categorias, o que pode indicar ausências de integrantes nestas categorias.'

par(mfrow=c(2,1))
