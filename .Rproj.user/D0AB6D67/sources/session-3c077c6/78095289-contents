# COMPARAÇÃO: Índices de Saúde
# 2012 x 2020
# ‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾

# Preparação dos dados -----

NHANES_12_f = data.frame(
  Saude = NHANES_12_t$HealthGen,
  Depressao = NHANES_12_t$Depressed,
  PerdaInteresse = NHANES_12_t$LittleInterest,
  IPobreza = NHANES_12_t$Poverty,
  Ano = "2012"
  )

NHANES_23_f = data.frame(
  Saude = NHANES_23_t$HUQ010_txt,
  Depressao = NHANES_23_t$DPQ020_txt,
  PerdaInteresse = NHANES_23_t$DPQ010_txt,
  IPobreza = NHANES_23_t$INDFMMPI,
  Ano = "2023"
)

comparison1 = rbind(NHANES_12_f, NHANES_23_f)

# Comparação da saúde -----

library(ggplot2)
ggplot(comparison1, aes(x = Saude, fill = Ano)) +
  geom_bar(color='black', position="dodge", 
           aes(y = after_stat(prop), group = Ano)) +
  theme_bw() +
  scale_fill_brewer(palette="Set2") +
  scale_y_continuous(labels = scales::percent) +
  labs(
    title = "Gráfico de níveis de saúde ao longo dos anos",
    x = "Nível de saúde",
    y = "Porcentagem de indivíduos",
    fill = "Ano\nde pesquisa"
  )

# Comparação da saúde mental -----

ggplot(comparison1, aes(x = Depressao, fill = Ano)) +
  geom_bar(color='black', position="dodge", 
           aes(y = after_stat(prop), group = Ano)) +
  theme_bw() +
  scale_fill_brewer(palette="Set3") +
  scale_y_continuous(labels = scales::percent) +
  labs(
    title = "Gráfico de níveis de indícios de depressão e perda de interesse\nao longo dos anos",
    x = "Proporção de dias\ncom sintomas de depressão",
    y = "Porcentagem de indivíduos") +
  theme(legend.position = "none") +
  
ggplot(comparison1, aes(x = PerdaInteresse, fill = Ano)) +
  geom_bar(color='black', position="dodge", 
           aes(y = after_stat(prop), group = Ano)) +
  theme_bw() +
  scale_fill_brewer(palette="Set3") +
  scale_y_continuous(labels = scales::percent) +
  labs(
    x = "Proporção de dias\ncom perda de interesse",
    y = "Porcentagem de indivíduos",
    fill = "Ano\nde pesquisa"
  )

# Comparação de índice de pobreza -----

summary(NHANES_12_t$Poverty)
summary(NHANES_23_t$INDFMMPI)

ggplot(comparison1, aes(y=IPobreza, x=Ano, fill=Ano)) + 
  geom_boxplot() +
  theme_bw() +
  scale_fill_brewer(palette="PuOr") +
  stat_summary(fun = mean, geom = "point", aes(group = 1), color = "brown") +
  labs(title = "Boxplot de índice de pobreza ao longo dos anos",
       y = "Índice de pobreza") +
  theme(legend.position = "none")

# Comparação de saúde x pobreza -----

ggplot(comparison1, aes(x = Saude, y = IPobreza , fill = Ano)) +
  geom_boxplot() +
  theme_bw() +
  scale_fill_brewer(palette="Spectral") +
  labs(
    title = "Gráfico de níveis de saúde x índice de pobreza",
    x = "Níveis de saúde",
    y = "Índice de pobreza",
    fill = "Ano\nde pesquisa"
  )

# Comparações de saúde mental x pobreza -----

library(patchwork)

ggplot(comparison1, aes(x = Depressao, y = IPobreza , fill = Ano)) +
  geom_boxplot() +
  theme_bw() +
  scale_fill_brewer(palette="Accent") +
  labs(
    title = "Gráfico de indícios de depressão e perda de interesse\nx índice de pobreza ao longo dos anos",
    x = "Proporção de dias\ncom sintomas de depressão",
    y = "Índice de pobreza",
    fill = "Ano\nde pesquisa"
  ) +
  theme(legend.position = "none") +
  
ggplot(comparison1, aes(x = PerdaInteresse, y = IPobreza , fill = Ano)) +
  geom_boxplot() +
  theme_bw() +
  scale_fill_brewer(palette="Accent") +
  labs(
    x = "Proporção de dias\ncom perda de interesse",
    y = "Índice de pobreza",
    fill = "Ano\nde pesquisa"
  )
